-- Navigation Button Creator
local currentPage = nil
local function CreateNavButton(name, icon, yPos)
    local Button = Instance.new("TextButton")
    Button.Name = name
    Button.Parent = Sidebar
    Button.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    Button.BorderSizePixel = 0
    Button.Position = UDim2.new(0, 10, 0, yPos)
    Button.Size = UDim2.new(1, -20, 0, 40)
    Button.Font = Enum.Font.Gotham
    Button.Text = "   " .. icon .. "  " .. name
    Button.TextColor3 = Color3.fromRGB(180, 180, 200)
    Button.TextSize = 14
    Button.TextXAlignment = Enum.TextXAlignment.Left
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = Button
    
    Button.MouseEnter:Connect(function()
        if currentPage ~= Button then
            Button.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
        end
    end)
    
    Button.MouseLeave:Connect(function()
        if currentPage ~= Button then
            Button.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
        end
    end)
    
    return Button
end

-- Create Pages
local pages = {}

local function CreatePage(name)
    local Page = Instance.new("ScrollingFrame")
    Page.Name = name .. "Page"
    Page.Parent = ContentPanel
    Page.BackgroundTransparency = 1
    Page.BorderSizePixel = 0
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.CanvasSize = UDim2.new(0, 0, 2, 0)
    Page.ScrollBarThickness = 4
    Page.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 150)
    Page.Visible = false
    
    pages[name] = Page
    return Page
end

